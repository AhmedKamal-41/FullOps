# Copy to `.env` at the repository root: `cp .env.example .env`
#
# Used by both `docker compose` (infra/compose/docker-compose.yml, invoked via the
# `make infra-*` targets from the repo root) and by each service when run locally
# via `make run-order` / `run-inventory` / `run-payment` / `run-fulfillment` — those
# targets source this file into the shell environment before starting Maven, and
# Spring Boot reads OS environment variables automatically.
#
# Every value below is fictional and only valid against the local Docker Compose
# stack. None of it is a real credential, and none of it is meant to look like a
# production secret — see docs/runbooks/local-infrastructure.md.

# --- Service HTTP ports ---
ORDER_SERVICE_PORT=8081
INVENTORY_SERVICE_PORT=8082
PAYMENT_SERVICE_PORT=8083
FULFILLMENT_SERVICE_PORT=8084

# --- PostgreSQL: one container, one isolated database/user per service ---
DB_HOST=localhost
DB_PORT=5432

# Container superuser, used only by the init script that creates the four
# per-service databases/users below. No service connects with this account.
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres-superuser-local-only-pw

ORDER_DB_NAME=order_db
ORDER_DB_USERNAME=order_service
ORDER_DB_PASSWORD=order-db-local-only-pw

INVENTORY_DB_NAME=inventory_db
INVENTORY_DB_USERNAME=inventory_service
INVENTORY_DB_PASSWORD=inventory-db-local-only-pw

PAYMENT_DB_NAME=payment_db
PAYMENT_DB_USERNAME=payment_service
PAYMENT_DB_PASSWORD=payment-db-local-only-pw

FULFILLMENT_DB_NAME=fulfillment_db
FULFILLMENT_DB_USERNAME=fulfillment_service
FULFILLMENT_DB_PASSWORD=fulfillment-db-local-only-pw

# --- Kafka (KRaft, single node, plaintext — local dev only) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Redis (disposable cache only — see docs/adr/0006-postgresql-per-service.md) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis-local-only-pw

# --- Keycloak / OIDC ---
# Bootstrap admin for Keycloak's own admin console — not an application credential.
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin-local-only-pw

# Fixed issuer so token validation is consistent whether Keycloak is reached from
# the host or from a container (see the KC_HOSTNAME comment in docker-compose.yml).
OIDC_ISSUER_URI=http://localhost:8080/realms/fulfillops

# Confidential client used only by local dev/smoke-test scripts to obtain tokens
# for the fictional demo users defined in infra/keycloak/realm-export.json. Not
# used by the services themselves, which only validate tokens, never request them.
OIDC_CLI_CLIENT_ID=fulfillops-cli
OIDC_CLI_CLIENT_SECRET=fulfillops-cli-local-secret
