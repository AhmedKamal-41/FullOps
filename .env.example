# Copy to `.env` for local Docker Compose runs.
#
# Phase 1 has no infrastructure yet, so this file only pins the per-service HTTP
# ports so the four applications don't collide when run together locally. Phase 2
# will extend this with Postgres, Kafka, Redis, and Keycloak configuration.

ORDER_SERVICE_PORT=8081
INVENTORY_SERVICE_PORT=8082
PAYMENT_SERVICE_PORT=8083
FULFILLMENT_SERVICE_PORT=8084
