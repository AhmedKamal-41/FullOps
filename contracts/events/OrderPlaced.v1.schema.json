{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fulfillops.dev/contracts/events/OrderPlaced.v1.schema.json",
  "title": "OrderPlaced.v1",
  "description": "Order Service accepted a new order and persisted it as PENDING in the same transaction as this outbox event.",
  "allOf": [
    { "$ref": "EventEnvelope.v1.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "OrderPlaced" },
        "eventVersion": { "const": 1 },
        "producer": { "const": "order-service" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["customerId", "idempotencyKey", "items", "totalAmount"],
          "properties": {
            "customerId": {
              "type": "string",
              "format": "uuid",
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
            },
            "idempotencyKey": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "items": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["sku", "quantity", "unitPrice"],
                "properties": {
                  "sku": { "type": "string", "minLength": 1 },
                  "quantity": { "type": "integer", "minimum": 1 },
                  "unitPrice": { "$ref": "Money.v1.schema.json" }
                }
              }
            },
            "totalAmount": { "$ref": "Money.v1.schema.json" }
          }
        }
      }
    }
  ]
}
