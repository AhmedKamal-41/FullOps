{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fulfillops.dev/contracts/events/OrderCancelled.v1.schema.json",
  "title": "OrderCancelled.v1",
  "description": "Order Service moved an order to CANCELLED after observing InventoryRejected, PaymentDeclined, or an operator-triggered FulfillmentStatusChanged (CANCELLED) — see docs/DOMAIN_MODEL.md's compensation table.",
  "allOf": [
    { "$ref": "EventEnvelope.v1.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "OrderCancelled" },
        "eventVersion": { "const": 1 },
        "producer": { "const": "order-service" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reasonCode"],
          "properties": {
            "reasonCode": {
              "type": "string",
              "enum": [
                "INVENTORY_REJECTED",
                "PAYMENT_DECLINED",
                "FULFILLMENT_CANCELLED",
                "CUSTOMER_REQUESTED",
                "OPERATOR_REQUESTED"
              ]
            },
            "reasonDetail": {
              "type": "string",
              "maxLength": 500
            }
          }
        }
      }
    }
  ]
}
