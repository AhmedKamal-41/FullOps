{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fulfillops.dev/contracts/events/InventoryReleased.v1.schema.json",
  "title": "InventoryReleased.v1",
  "description": "Inventory Service released a prior reservation back to available stock, as compensation after a payment decline or a fulfillment cancellation.",
  "allOf": [
    { "$ref": "EventEnvelope.v1.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "InventoryReleased" },
        "eventVersion": { "const": 1 },
        "producer": { "const": "inventory-service" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reservationId", "items", "reasonCode"],
          "properties": {
            "reservationId": {
              "type": "string",
              "format": "uuid",
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
            },
            "items": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["sku", "quantity"],
                "properties": {
                  "sku": { "type": "string", "minLength": 1 },
                  "quantity": { "type": "integer", "minimum": 1 }
                }
              }
            },
            "reasonCode": {
              "type": "string",
              "enum": ["PAYMENT_DECLINED", "FULFILLMENT_CANCELLED", "ORDER_CANCELLED"]
            }
          }
        }
      }
    }
  ]
}
