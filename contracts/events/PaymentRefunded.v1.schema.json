{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fulfillops.dev/contracts/events/PaymentRefunded.v1.schema.json",
  "title": "PaymentRefunded.v1",
  "description": "Payment Service refunded a prior authorization, as compensation after a fulfillment cancellation.",
  "allOf": [
    { "$ref": "EventEnvelope.v1.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "PaymentRefunded" },
        "eventVersion": { "const": 1 },
        "producer": { "const": "payment-service" },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["paymentId", "amount", "reasonCode"],
          "properties": {
            "paymentId": {
              "type": "string",
              "format": "uuid",
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
            },
            "amount": { "$ref": "Money.v1.schema.json" },
            "reasonCode": {
              "type": "string",
              "enum": ["FULFILLMENT_CANCELLED"]
            }
          }
        }
      }
    }
  ]
}
