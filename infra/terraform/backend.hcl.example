# Copy to backend.hcl (git-ignored) and pass to init:
#   terraform init -backend-config=backend.hcl
#
# The S3 bucket must already exist, with versioning and encryption enabled. S3 native
# locking (use_lockfile) needs no separate DynamoDB table.
bucket       = "REPLACE_ME-fulfillops-tfstate"
key          = "fulfillops/dev/terraform.tfstate"
region       = "us-east-1"
encrypt      = true
use_lockfile = true
