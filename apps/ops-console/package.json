{
  "name": "ops-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 5173 --strictPort",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "screenshots": "playwright test --config=playwright.screenshots.config.ts",
    "seed": "bash ../../scripts/seed-demo-data.sh"
  },
  "dependencies": {
    "@mantine/charts": "9.4.1",
    "@mantine/core": "9.4.1",
    "@mantine/form": "9.4.1",
    "@mantine/hooks": "9.4.1",
    "@mantine/notifications": "9.4.1",
    "@tabler/icons-react": "3.45.0",
    "@tanstack/react-query": "5.101.3",
    "jwt-decode": "4.0.0",
    "oidc-client-ts": "3.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-oidc-context": "3.3.1",
    "react-router-dom": "7.18.1",
    "recharts": "3.10.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.6.4",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest-axe": "3.5.9",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.38.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.16",
    "globals": "16.5.0",
    "jest-axe": "10.0.0",
    "jsdom": "26.0.0",
    "msw": "2.15.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
